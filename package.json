{
  "name": "bytheslice",
  "version": "4.1.0",
  "private": false,
  "description": "A grab-and-go pizza shop for shipping software. Daily prep, slice-by-slice service, /goal-driven autonomous mode.",
  "bin": {
    "bytheslice": "./bin/bytheslice.js"
  },
  "scripts": {
    "install:dry-run": "node ./bin/bytheslice.js install --target both --dry-run",
    "install:skills:dry-run": "node ./bin/bytheslice.js install --mode skills --skill setup-shop --skill sell-slice --dry-run"
  },
  "files": [
    "bin",
    "commands",
    "skills",
    "scripts/install",
    ".cursor-plugin",
    ".claude-plugin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steve-piece/bytheslice.git"
  },
  "keywords": [
    "cursor-plugin",
    "claude-code-plugin",
    "skills",
    "prd",
    "ci-cd",
    "development-workflow",
    "vertical-slices",
    "agent-workflow",
    "pizza-shop"
  ]
}
