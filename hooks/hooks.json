{
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/precheck-skill.sh\"",
          "timeout": 5,
          "statusMessage": "Running bytheslice skill preconditions..."
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/shop-status.sh\"",
          "timeout": 3
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-guard.sh\"",
          "timeout": 3,
          "statusMessage": "Checking commit branch..."
        }
      ]
    },
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stage-plan-guard.sh\"",
          "timeout": 3,
          "statusMessage": "Checking stage-plan write guard..."
        },
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/library-gate-guard.sh\"",
          "timeout": 3
        }
      ]
    },
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stage-plan-guard.sh\"",
          "timeout": 3,
          "statusMessage": "Checking stage-plan write guard..."
        },
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/library-gate-guard.sh\"",
          "timeout": 3
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/compact-snapshot.sh\"",
          "timeout": 4
        }
      ]
    }
  ]
}
